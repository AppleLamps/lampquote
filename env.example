# Server-only (set in Vercel Project → Environment Variables)
POE_API_KEY=
# Optional: shown as HTTP-Referer for Poe leaderboard attribution
POE_APP_URL=https://your-deployment.vercel.app
# Optional: text model for the image “prompt optimizer” step (default: Gemini-3-Pro)
# POE_IMAGE_PROMPT_MODEL=Gemini-3-Pro

# Local dev: only needed if the UI and API run on different origins
# VITE_API_BASE=http://127.0.0.1:3000
